<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Resultados de la Votación</title>
    <link rel="stylesheet" href="../public/style.css" />
    <script src="../public/app.js" defer></script>
  </head>
  <body>
    <main class="container">
      <section class="card resultados-card">
        <div class="section-header">
          <h1>Resultados de la votación</h1>
          <p>Consulta cómo van las opciones y cuánto ha votado la comunidad.</p>
        </div>

        <div class="stats-row">
          <div class="stat-card">
            <span id="totalVotos" class="stat-value">0</span>
            <span class="stat-label">Votos totales</span>
          </div>
          <div class="stat-card">
            <span id="opcionesCount" class="stat-value">0</span>
            <span class="stat-label">Opciones</span>
          </div>
        </div>

        <div id="resultadosList" class="resultados-list"></div>

        <div class="actions-row">
          <a class="btn secondary" href="index.ejs">Volver a votar</a>
          <button id="reiniciarBtn" type="button" class="btn">Reiniciar votos</button>
        </div>
      </section>
    </main>
  </body>
</html>
